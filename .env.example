# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# .env is gitignored — your keys will not be committed.
# eval.sh sources .env automatically before each run.

# Required: OpenAI API key for the agent model and user simulator
OPENAI_API_KEY=sk-...

# Optional: override the default agent model (default: gpt-4.1-mini)
# SOLVER_MODEL=gpt-4.1-mini

# Optional: override the user simulator model (default: gpt-4.1-2025-04-14)
# USER_MODEL=gpt-4.1-2025-04-14

# Optional: run only a subset of the 97 banking tasks for fast iteration
# SAMPLE_FRAC=0.1
